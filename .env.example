# Bot
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_IDS=123456789

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutrition_bot
DB_USER=bot_user
DB_PASSWORD=bot_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Tinkoff Payment
TINKOFF_TERMINAL_KEY=test_terminal_key
TINKOFF_PASSWORD=test_password
TINKOFF_TEST_MODE=true

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# App Settings
TRIAL_DAYS=3
BONUS_PER_REFERRAL=10000
PARTNER_REWARD=30000

# Webhook
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log